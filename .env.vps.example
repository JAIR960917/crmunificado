# -----------------------------------------------------------------------------
# Supabase self-hosted (Docker Compose)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=change-me
POSTGRES_DB=postgres

# Use at least 32 chars random string
JWT_SECRET=change-me-with-32+-chars

# Supabase API keys (legacy HS256 JWTs) - generate for your env
ANON_KEY=change-me
SERVICE_ROLE_KEY=change-me

# Needed by Realtime
SECRET_KEY_BASE=change-me-with-32+-chars

# Used by Studio + Auth redirects
SITE_URL=https://crm.joonker.com.br
SUPABASE_PUBLIC_URL=https://api.joonker.com.br

# Extra redirect URLs allowed for Auth (comma-separated)
ADDITIONAL_REDIRECT_URLS=https://crm.joonker.com.br,https://api.joonker.com.br

# Optional: lock Studio behind basic auth (Kong)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin

# Optional: Kong exposed port
KONG_HTTP_PORT=8000

# Frontend nginx port
FRONTEND_PORT=8080

# Optional: Storage limits (bytes)
STORAGE_FILE_SIZE_LIMIT=52428800

# Used by Postgres Meta
PG_META_CRYPTO_KEY=change-me-with-32+-chars


# WhatsApp via API Full (https://api.apifull.com.br) — usado pelas edge functions
# apifull-whatsapp, send-whatsapp e cobranca-flow-advance.
APIFULL_API_KEY=

# Segredo para cron/pg_net chamar edge functions (openssl rand -hex 32)
CRON_SECRET=
