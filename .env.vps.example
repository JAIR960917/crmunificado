# -----------------------------------------------------------------------------
# Supabase self-hosted (Docker Compose)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=change-me
POSTGRES_DB=postgres

# Use at least 32 chars random string
JWT_SECRET=change-me-with-32+-chars

# Supabase API keys (legacy HS256 JWTs) - generate for your env
ANON_KEY=change-me
SERVICE_ROLE_KEY=change-me

# Needed by Realtime
SECRET_KEY_BASE=change-me-with-32+-chars

# JWT access token lifetime in seconds (default 28800 = 8h). Refresh keeps session longer.
JWT_EXP=28800

# Used by Studio + Auth redirects
SITE_URL=https://crm.joonker.com.br
SUPABASE_PUBLIC_URL=https://api.joonker.com.br

# Extra redirect URLs allowed for Auth (comma-separated)
ADDITIONAL_REDIRECT_URLS=https://crm.joonker.com.br,https://api.joonker.com.br

# Optional: lock Studio behind basic auth (Kong)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin

# Optional: Kong exposed port
KONG_HTTP_PORT=8000

# Frontend nginx port
FRONTEND_PORT=8080

# Optional: Storage limits (bytes)
STORAGE_FILE_SIZE_LIMIT=52428800

# Used by Postgres Meta
PG_META_CRYPTO_KEY=change-me-with-32+-chars


# WhatsApp via API Full (https://api.apifull.com.br) — legado (QR Code / sessão)
# Usado enquanto whatsapp_provider = apifull no CRM.
APIFULL_API_KEY=

# WhatsApp Cloud API (Meta) — após aprovação no Meta for Developers
# Usado por send-whatsapp, cobranca-flow-advance, whatsapp-webhook e meta-whatsapp.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_WABA_ID=

# Segredo para cron/pg_net chamar edge functions (openssl rand -hex 32)
CRON_SECRET=

# Segredo único para criar o primeiro admin via edge function seed-admin (openssl rand -hex 32)
# Header: x-bootstrap-secret. Não exponha no frontend.
SEED_ADMIN_SECRET=

# -----------------------------------------------------------------------------
# Crediário (módulo de venda no boleto absorvido do antigo app consultasjoonker)
# -----------------------------------------------------------------------------

# Serasa Experian (consulta-cpf) — score e pendências de CPF
SERASA_CLIENT_ID=
SERASA_CLIENT_SECRET=
SERASA_RETAILER_CNPJ=
SERASA_ENV=uat

# APIFULL (apifull-consulta-cpf) — consulta de CPF alternativa (distinto do APIFULL_API_KEY de WhatsApp acima)
APIFULL_TOKEN=

# Cora (boletos/PIX) — fallback global; o normal é cadastrar por loja em
# Crediário > Credenciais (tabela crediario_company_credentials), já que cada
# empresa emite pelo seu próprio gateway Cora.
CORA_CLIENT_ID=
CORA_CERTIFICATE=
CORA_PRIVATE_KEY=

# ZapSign (assinatura digital de contratos)
ZAPSIGN_API_TOKEN=
ZAPSIGN_ENV=sandbox
ZAPSIGN_WEBHOOK_SECRET=

# Assertiva (importação de contratos)
ASSERTIVA_CLIENT_ID=
ASSERTIVA_CLIENT_SECRET=

# Google Drive (importação de contratos via gdrive-importar-contratos)
GOOGLE_SERVICE_ACCOUNT_JSON=
